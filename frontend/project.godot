; Engine configuration file.
; Godot 4.2+ project for The Genius Game web client.

config_version=5

[application]

config/name="The Genius Game"
config/description="Multi-title web board game platform — Omok first."
run/main_scene="res://scenes/lobby.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://assets/icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[autoload]

GameSession="*res://scripts/game_session.gd"
NetClient="*res://scripts/net_client.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.web="gl_compatibility"
